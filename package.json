{
	"name": "@eko24ive/pi-jira",
	"version": "0.1.0",
	"private": true,
	"description": "Pi package for safe, workspace-mapped Jira Cloud operations.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eko24ive/pi-jira.git"
	},
	"homepage": "https://github.com/eko24ive/pi-jira#readme",
	"bugs": {
		"url": "https://github.com/eko24ive/pi-jira/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"jira",
		"jira-cloud"
	],
	"files": [
		"index.ts",
		"src/",
		"README.md",
		"docs/maintenance.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"dev": "pi --no-extensions -e ./index.ts",
		"test": "bun test",
		"build:smoke": "bun build index.ts --target=node --outfile=/tmp/pi-jira-index.js --external @earendil-works/pi-coding-agent --external typebox",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "ultracite check",
		"check:ci": "biome ci .",
		"fix": "ultracite fix",
		"commit": "cz",
		"commitlint": "commitlint"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@earendil-works/pi-coding-agent": "0.80.10",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"lefthook": "^2.1.6",
		"typebox": "1.1.38",
		"ultracite": "7.6.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
