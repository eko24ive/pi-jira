{
	"name": "@eko24ive/pi-jira",
	"version": "0.1.0",
	"description": "Pi package for safe, workspace-mapped Jira Cloud operations.",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/eko24ive/pi-jira.git"
	},
	"homepage": "https://github.com/eko24ive/pi-jira#readme",
	"bugs": {
		"url": "https://github.com/eko24ive/pi-jira/issues"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent",
		"jira",
		"jira-cloud"
	],
	"files": [
		"index.ts",
		"src/",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"dev": "pi --no-extensions -e ./index.ts",
		"test": "bun test",
		"build:smoke": "bun build index.ts --target=node --outfile=/tmp/pi-jira-index.js --external @earendil-works/pi-coding-agent --external typebox",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "ultracite check",
		"check:ci": "biome ci .",
		"fix": "ultracite fix",
		"commit": "cz",
		"commitlint": "commitlint",
		"release": "semantic-release"
	},
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"release": {
		"repositoryUrl": "https://github.com/eko24ive/pi-jira.git",
		"branches": [
			"main"
		],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			[
				"@semantic-release/changelog",
				{
					"changelogFile": "CHANGELOG.md"
				}
			],
			"@semantic-release/npm",
			"@semantic-release/github",
			[
				"@semantic-release/git",
				{
					"assets": [
						"package.json",
						"CHANGELOG.md"
					],
					"message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
				}
			]
		]
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@earendil-works/pi-coding-agent": "0.79.9",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"lefthook": "^2.1.6",
		"semantic-release": "^25.0.3",
		"typebox": "1.1.38",
		"ultracite": "7.6.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	}
}
